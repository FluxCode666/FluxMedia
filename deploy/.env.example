# FluxMedia 单服务生产环境模板。
# 复制为 deploy/.env 后填写真实值；不要提交包含机密的 .env。

# 镜像由 deploy-production.yml 更新为本次不可变版本。
FLUXMEDIA_IMAGE=ghcr.io/fluxcode666/fluxmedia-web
FLUXMEDIA_MIGRATE_IMAGE=ghcr.io/fluxcode666/fluxmedia-migrate
FLUXMEDIA_TAG=latest

# web 只绑定宿主机回环地址，由宿主机 Nginx 对外提供 HTTPS。
BIND_HOST=127.0.0.1
WEB_PORT=3001

# 公网域名同时用于前端构建、鉴权回调与可信来源校验。
# 请替换为实际域名；示例文件不包含生产域名。
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=FluxMedia
BETTER_AUTH_URL=https://your-domain.com
BETTER_AUTH_TRUSTED_ORIGINS=https://your-domain.com

# 必填机密。认证密钥可用 openssl rand -base64 32 生成。
DATABASE_URL=
BETTER_AUTH_SECRET=
# 线上使用外部 Redis；密码以独立变量传递，无需 URL 编码。生产必须使用 TLS 或受控内网连接。
REDIS_HOST=redis.example.internal
REDIS_PORT=6379
# Redis ACL 用户名可留空，以使用默认用户。
REDIS_USERNAME=
REDIS_PASSWORD=change-me
REDIS_DB=4

# 本地持久化目录位于 Docker 命名卷中。
LOCAL_STORAGE_PATH=/app/storage
NEXT_PUBLIC_AVATARS_BUCKET_NAME=avatars
NEXT_PUBLIC_GENERATIONS_BUCKET_NAME=generations

# 单实例默认启用内部调度器；多实例部署必须重新评估任务互斥策略。
SELF_USE_MODE_ENABLED=true
# 首次自用超管的账号与密码；密码是机密，必须填入高强度值且不得提交。
FLUXMEDIA_SUPER_ADMIN_EMAIL=
FLUXMEDIA_SUPER_ADMIN_PASSWORD=
INTERNAL_JOB_SCHEDULER_ENABLED=true
APP_TIME_ZONE=Asia/Shanghai
TZ=Asia/Shanghai

# Nginx 是唯一可信反向代理，因此允许应用读取其转发的客户端地址头。
RATE_LIMIT_TRUSTED_PROXY=true

# 本部署不提供注册机 sidecar。Compose 还会显式覆盖为空，防止误连旧服务。
CHATGPT_REGISTER_URL=
CHATGPT_REGISTER_SECRET=

# 可选能力可在后台配置；这里给出安全的最小启动默认值。
PAYMENT_PROVIDER=none
NEXT_PUBLIC_PAYMENT_PROVIDER=none
EMAIL_PROVIDER=
CONTENT_MODERATION_ENABLED=false
CONTENT_MODERATION_PROVIDER=none

# 对象存储、支付、邮件、审核、监控等可选变量见仓库根目录 .env.example。
